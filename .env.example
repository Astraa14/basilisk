# Copy this file to `.env` (gitignored). Never put real keys in this example file.

BASILISK_LLM_API_KEY=sk-your-key-here
# OpenAI-compatible base URL (NVIDIA, OpenAI, local Ollama, etc.)
BASILISK_LLM_BASE_URL=https://api.openai.com/v1
BASILISK_LLM_MODEL=gpt-4o-mini

# Optional: HackAgent-style local default (no cloud key)
# BASILISK_LLM_BASE_URL=http://localhost:11434/v1
# BASILISK_LLM_API_KEY=ollama
# BASILISK_LLM_MODEL=llama3.2
